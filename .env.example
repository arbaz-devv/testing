# Database – Prisma uses DATABASE_URL (see prisma/schema.prisma)
# Local dev: use a local Postgres (create DB: createdb cryptoi)
DATABASE_URL="postgresql://localhost:5432/cryptoi"

# Production / Railway: use your cloud Postgres or Prisma Data Platform URL
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT secret for session tokens. REQUIRED in production (min 32 chars). Omit in dev for default.
# JWT_SECRET=your-at-least-32-character-secret-in-production

# Optional: Port (default 8000)
PORT=9000

# Optional: CORS origin for frontend (e.g. http://localhost:3000). Comma-separated for multiple.
# CORS_ORIGIN=http://localhost:3000

# Optional: Redis for custom analytics (in-memory store). If not set, analytics tracking is no-op.
# REDIS_URL=redis://localhost:6379

# Optional: API key for admin API (X-Admin-Key or ?key=). Same key can be used for server-to-server.
# ANALYTICS_API_KEY=your-secret-key
# ADMIN_API_KEY=your-secret-key

# Admin login (optional). If set, POST /api/admin/auth/login accepts email + password and returns a JWT.
# Generate password hash: node -e "require('bcryptjs').hash('yourpassword', 10).then(h=>console.log(h))"
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD_HASH=$2a$10$...
